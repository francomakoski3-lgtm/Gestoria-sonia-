# ── Cache control ─────────────────────────────────────────────
# Imágenes y fuentes: cachear 1 día (se actualizan seguido durante el desarrollo)
<FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|ico|woff|woff2|ttf)$">
  Header set Cache-Control "public, max-age=86400, must-revalidate"
</FilesMatch>

# CSS y JS: siempre verificar si cambió (cambio instantáneo)
<FilesMatch "\.(css|js)$">
  Header set Cache-Control "no-cache, must-revalidate"
  Header set Pragma "no-cache"
</FilesMatch>

# HTML: sin caché (siempre pide la versión más nueva)
<FilesMatch "\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>
