# URLs limpias: /pagina carga pagina.html y /pagina.html redirige a /pagina
Options -MultiViews
DirectoryIndex index.html
RewriteEngine On

RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Cache control
# Imagenes y fuentes: cachear 1 dia
<FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|ico|woff|woff2|ttf)$">
  Header set Cache-Control "public, max-age=86400, must-revalidate"
</FilesMatch>

# CSS y JS: siempre verificar si cambio
<FilesMatch "\.(css|js)$">
  Header set Cache-Control "no-cache, must-revalidate"
  Header set Pragma "no-cache"
</FilesMatch>

# HTML: sin cache
<FilesMatch "\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>

# Evitar la indexacion de paneles privados y artefactos internos
<FilesMatch "^(admin|gracias-reserva|cotizacion-transferencia-resultado)\.html$">
  Header set X-Robots-Tag "noindex, nofollow, noarchive, nosnippet"
</FilesMatch>

<FilesMatch "^review_.*\.html$">
  Header set X-Robots-Tag "noindex, nofollow, noarchive, nosnippet"
</FilesMatch>
